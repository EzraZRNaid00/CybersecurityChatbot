@{
    ViewData["Title"] = "Dashboard";
}

<!-- Hero Banner with Animation -->
<div class="hero-section text-center text-white py-5 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 0 0 50px 50px;">
    <div class="container">
        <h1 class="display-3 fw-bold animate-fade-in">EventEase</h1>
        <p class="lead animate-slide-up">Your Premier Venue Booking Management System</p>
        <div class="mt-4 animate-slide-up delay-1">
            <a asp-controller="Venues" class="btn btn-light btn-lg mx-2 rounded-pill px-4" data-bs-toggle="tooltip" title="Browse all venues">
                <i class="fas fa-building me-2"></i>Browse Venues
            </a>
            <a asp-controller="Bookings" class="btn btn-outline-light btn-lg mx-2 rounded-pill px-4" data-bs-toggle="tooltip" title="View all bookings">
                <i class="fas fa-calendar-alt me-2"></i>View Bookings
            </a>
        </div>
    </div>
</div>

<div class="container mt-4">
    <!-- Dashboard Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
            <a asp-controller="Venues" asp-action="Index" style="text-decoration: none;">
                <div class="card border-0 shadow-lg card-hover" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border-radius: 20px; cursor: pointer;">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-white text-primary mb-3 mx-auto">
                            <i class="fas fa-building fa-3x"></i>
                        </div>
                        <h3 id="venueCount" class="fw-bold display-4 skeleton-loading">---</h3>
                        <p class="mb-0 text-uppercase small fw-bold">Total Venues</p>
                        <div class="mt-3">
                            <small><i class="fas fa-arrow-right"></i> View Details</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
            <a asp-controller="Events" asp-action="Index" style="text-decoration: none;">
                <div class="card border-0 shadow-lg card-hover" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white; border-radius: 20px; cursor: pointer;">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-white text-primary mb-3 mx-auto">
                            <i class="fas fa-calendar-alt fa-3x"></i>
                        </div>
                        <h3 id="eventCount" class="fw-bold display-4 skeleton-loading">---</h3>
                        <p class="mb-0 text-uppercase small fw-bold">Total Events</p>
                        <div class="mt-3">
                            <small><i class="fas fa-arrow-right"></i> View Details</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        
        <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
            <a asp-controller="Bookings" asp-action="Index" style="text-decoration: none;">
                <div class="card border-0 shadow-lg card-hover" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white; border-radius: 20px; cursor: pointer;">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-white text-primary mb-3 mx-auto">
                            <i class="fas fa-ticket-alt fa-3x"></i>
                        </div>
                        <h3 id="bookingCount" class="fw-bold display-4 skeleton-loading">---</h3>
                        <p class="mb-0 text-uppercase small fw-bold">Total Bookings</p>
                        <div class="mt-3">
                            <small><i class="fas fa-arrow-right"></i> View Details</small>
                        </div>
                    </div>
                </div>
            </a>
        </div>
    </div>
    
    <!-- Charts Section -->
    <div class="row mb-5">
        <div class="col-md-6" data-aos="fade-right">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-white">
                    <h5><i class="fas fa-chart-bar me-2 text-primary"></i>Booking Statistics</h5>
                </div>
                <div class="card-body">
                    <canvas id="bookingChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6" data-aos="fade-left">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-white">
                    <h5><i class="fas fa-chart-pie me-2 text-primary"></i>Distribution</h5>
                </div>
                <div class="card-body">
                    <canvas id="distributionChart" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="row mb-5" data-aos="zoom-in">
        <div class="col-12">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-white border-0 pt-4">
                    <h4 class="mb-0"><i class="fas fa-bolt text-primary me-2"></i>Quick Actions</h4>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <a asp-controller="Venues" asp-action="Create" class="btn btn-outline-primary w-100 py-3 rounded-pill" data-bs-toggle="tooltip" title="Add a new venue to the system">
                                <i class="fas fa-plus-circle me-2"></i>Add New Venue
                            </a>
                        </div>
                        <div class="col-md-4">
                            <a asp-controller="Events" asp-action="Create" class="btn btn-outline-success w-100 py-3 rounded-pill" data-bs-toggle="tooltip" title="Add a new event to the system">
                                <i class="fas fa-plus-circle me-2"></i>Add New Event
                            </a>
                        </div>
                        <div class="col-md-4">
                            <a asp-controller="Bookings" asp-action="Create" class="btn btn-outline-info w-100 py-3 rounded-pill" data-bs-toggle="tooltip" title="Create a new booking">
                                <i class="fas fa-plus-circle me-2"></i>Create Booking
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Recent Bookings Section -->
    <div class="row" data-aos="fade-up">
        <div class="col-12">
            <div class="card border-0 shadow-lg">
                <div class="card-header bg-white">
                    <h5><i class="fas fa-clock me-2 text-primary"></i>Recent Bookings</h5>
                </div>
                <div class="card-body">
                    <div id="recentBookings">
                        <p class="text-muted text-center">Loading...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 0 0 50px 50px;
        margin-top: -24px;
    }
    
    .icon-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.3s ease;
    }
    
    .card-hover {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .card-hover:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15) !important;
    }
    
    .card-hover:hover .icon-circle {
        transform: scale(1.1);
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }
    
    .animate-fade-in {
        animation: fadeIn 1s ease-out;
    }
    
    .animate-slide-up {
        animation: slideUp 0.8s ease-out;
    }
    
    .delay-1 {
        animation-delay: 0.3s;
        opacity: 0;
        animation-fill-mode: forwards;
    }
</style>

@section Scripts {
    <script>
        // Fetch counts and update dashboard
        document.addEventListener('DOMContentLoaded', function() {
            fetch('@Url.Action("GetCounts", "Home")')
                .then(function(response) { return response.json(); })
                .then(function(data) {
                    document.getElementById('venueCount').textContent = data.venueCount;
                    document.getElementById('eventCount').textContent = data.eventCount;
                    document.getElementById('bookingCount').textContent = data.bookingCount;
                    
                    // Remove skeleton loading class
                    document.querySelectorAll('.skeleton-loading').forEach(el => {
                        el.classList.remove('skeleton-loading');
                    });
                })
                .catch(function(error) { console.log('Error:', error); });
        });
        
        // Booking Statistics Chart
        fetch('/Home/GetCounts')
            .then(response => response.json())
            .then(data => {
                const ctx = document.getElementById('bookingChart')?.getContext('2d');
                if (ctx) {
                    new Chart(ctx, {
                        type: 'bar',
                        data: {
                            labels: ['Venues', 'Events', 'Bookings'],
                            datasets: [{
                                label: 'Count',
                                data: [data.venueCount, data.eventCount, data.bookingCount],
                                backgroundColor: ['#667eea', '#f093fb', '#4facfe'],
                                borderRadius: 10
                            }]
                        },
                        options: {
                            responsive: true,
                            plugins: {
                                legend: { position: 'top' }
                            }
                        }
                    });
                }
                
                const ctx2 = document.getElementById('distributionChart')?.getContext('2d');
                if (ctx2) {
                    new Chart(ctx2, {
                        type: 'doughnut',
                        data: {
                            labels: ['Venues', 'Events', 'Bookings'],
                            datasets: [{
                                data: [data.venueCount, data.eventCount, data.bookingCount],
                                backgroundColor: ['#667eea', '#f093fb', '#4facfe'],
                                borderRadius: 10
                            }]
                        }
                    });
                }
            });
        
        // Fetch recent bookings
        fetch('/Home/GetRecentBookings')
            .then(response => response.json())
            .then(data => {
                const container = document.getElementById('recentBookings');
                if (data && data.length > 0) {
                    let html = '<div class="table-responsive"><table class="table table-sm table-hover">';
                    html += '<thead class="table-light"><tr><th>Customer</th><th>Event</th><th>Venue</th><th>Date</th><th>Tickets</th></tr></thead><tbody>';
                    data.forEach(booking => {
                        html += `<tr>
                                    <td>${escapeHtml(booking.customerName)}</td>
                                    <td>${escapeHtml(booking.eventName)}</td>
                                    <td>${escapeHtml(booking.venueName)}</td>
                                    <td>${booking.bookingDate}</td>
                                    <td>${booking.tickets}</td>
                                 </tr>`;
                    });
                    html += '</tbody></table></div>';
                    container.innerHTML = html;
                } else {
                    container.innerHTML = '<p class="text-muted text-center">No recent bookings found.</p>';
                }
            });
        
        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }
    </script>
}