@model EventEase1.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>Delete Event
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-warning me-2"></i>
                        Are you sure you want to delete this event? This action cannot be undone.
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Event Name:</div>
                        <div class="col-md-8">@Model.Name</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">Start Date:</div>
                        <div class="col-md-8">@Model.StartDate.ToShortDateString()</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4 fw-bold">End Date:</div>
                        <div class="col-md-8">@Model.EndDate.ToShortDateString()</div>
                    </div>

                    <hr />

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="EventId" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash me-1"></i> Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>