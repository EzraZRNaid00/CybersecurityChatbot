@model IEnumerable<EventEase1.Models.Booking>

@{
    ViewData["Title"] = "Bookings";
}

<h1>Bookings</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Booking</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Event Name</th>
            <th>Venue Name</th>
            <th>Customer Name</th>
            <th>Booking Date</th>
            <th>Number of Tickets</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Event?.Name</td
                <td>@item.Venue?.Name</td
                <td>@item.CustomerName</td
                <td>@item.BookingDate.ToShortDateString()</td
                <td>@item.NumberOfTickets</td
                <td>
                    <a asp-action="Edit" asp-route-id="@item.BookingId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BookingId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BookingId">Delete</a>
                </td
            </tr>
        }
    </tbody>
</table>